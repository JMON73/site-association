---
import PageLayout from '../../layouts/PageLayout.astro';
import { SITE } from '../../data/site';
---

<PageLayout title="Contact" description="Contactez le CARAU, Cercle des Amis du Rugby Albertville Ugine.">
  <section class="contact-header">
    <div class="contact-header-inner">
      <h1>Contact</h1>
      <p class="contact-intro">Une question, une envie de nous rejoindre ? Écrivez-nous.</p>
    </div>
  </section>

  <section class="contact-content">
    <div class="contact-content-inner">

      <div class="contact-info">
        <div class="contact-info-item">
          <p class="contact-info-label">Email</p>
          <a href={`mailto:${SITE.email}`} class="contact-info-value">{SITE.email}</a>
        </div>
        <div class="contact-info-item">
          <p class="contact-info-label">Suivez-nous</p>
          <div class="contact-info-social">
            <a href={SITE.facebook} class="contact-info-value">Facebook</a>
            <a href={SITE.instagram} class="contact-info-value">Instagram</a>
          </div>
        </div>
      </div>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="contact-form-hidden" hidden>
          <label>
            Ne pas remplir si vous êtes humain : <input name="bot-field" />
          </label>
        </p>

        <div class="contact-field">
          <label for="nom">Nom</label>
          <input type="text" id="nom" name="nom" required />
        </div>

        <div class="contact-field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="contact-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="contact-submit-btn">Envoyer</button>
      </form>

    </div>
  </section>
</PageLayout>

<style>
  .contact-header {
    background-color: var(--color-black);
    padding: var(--space-8) var(--space-3) var(--space-6);
    text-align: center;
  }

  .contact-header-inner h1 {
    color: var(--color-white);
    font-size: 32px;
  }

  .contact-intro {
    color: var(--color-gray);
    margin-top: var(--space-1);
  }

  .contact-content {
    padding: var(--space-8) var(--space-3);
  }

  .contact-content-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-info {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-light);
  }

  .contact-info-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray);
    margin-bottom: 4px;
  }

  .contact-info-value {
    font-size: 15px;
    color: var(--color-black);
  }

  .contact-info-social {
    display: flex;
    gap: var(--space-2);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact-field label {
    font-size: 14px;
    font-weight: 500;
  }

  .contact-field input,
  .contact-field textarea {
    font-family: var(--font-sans);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-sm);
    background-color: var(--color-white);
    resize: vertical;
  }

  .contact-field input:focus-visible,
  .contact-field textarea:focus-visible {
    outline: 2px solid var(--color-red);
    outline-offset: 2px;
  }

 .contact-submit-btn {
  align-self: flex-start;
  margin-top: var(--space-1);
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 500;
  padding: 12px 24px;
  background-color: var(--color-red);
  color: var(--color-white);
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background-color var(--transition-base);
}

.contact-submit-btn:hover {
  background-color: var(--color-red-dark);
}
</style>