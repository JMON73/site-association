---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const actualites = await getCollection('actualites');
  return actualites.map((a) => ({
    params: { slug: a.id },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const dateFormatee = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(article.data.date);
---

<PageLayout title={article.data.title} description={article.data.resume}>
  <article class="article-detail">
    <div class="article-detail-header">
      {article.data.image ? (
        <img src={article.data.image} alt="" class="article-detail-image" />
      ) : (
        <div class="article-detail-placeholder" aria-hidden="true">CARAU</div>
      )}
    </div>

    <div class="article-detail-inner">
      <p class="article-detail-date">{dateFormatee}</p>
      <h1 class="article-detail-title">{article.data.title}</h1>

      <div class="article-detail-body">
        <Content />
      </div>

      <a href="/actualites" class="article-detail-back">&larr; Retour aux actualités</a>
    </div>
  </article>
</PageLayout>

<style>
  .article-detail-header {
    width: 100%;
    height: 320px;
    background-color: var(--color-gray-light);
  }

  .article-detail-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-detail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--color-gray);
    letter-spacing: 0.05em;
  }

  .article-detail-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-3);
  }

  .article-detail-date {
    font-size: 14px;
    color: var(--color-gray);
  }

  .article-detail-title {
    font-size: 32px;
    margin-top: var(--space-1);
  }

  .article-detail-body {
    margin-top: var(--space-4);
    font-size: 16px;
    line-height: 1.7;
  }

  .article-detail-back {
    display: inline-block;
    margin-top: var(--space-5);
    font-size: 14px;
    color: var(--color-gray);
  }

  @media (min-width: 700px) {
    .article-detail-title {
      font-size: 40px;
    }
  }
</style>