---
import PageLayout from '../../layouts/PageLayout.astro';
import NewsCard from '../../components/cards/NewsCard.astro';
import { getCollection } from 'astro:content';

const toutesLesActualites = await getCollection('actualites');
const triees = toutesLesActualites.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="Actualités" description="Toutes les actualités du CARAU.">
  <section class="news-header">
    <div class="news-header-inner">
      <h1>Actualités</h1>
      <p class="news-intro">Les dernières nouvelles du club.</p>
    </div>
  </section>

  <section class="news-content">
    <div class="news-content-inner">
      {triees.length > 0 ? (
        <div class="news-grid">
          {triees.map((article) => (
            <NewsCard
              slug={article.id}
              title={article.data.title}
              date={article.data.date}
              resume={article.data.resume}
              image={article.data.image}
            />
          ))}
        </div>
      ) : (
        <p class="news-empty">Aucune actualité pour le moment.</p>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .news-header {
    background-color: var(--color-black);
    padding: var(--space-8) var(--space-3) var(--space-6);
    text-align: center;
  }

  .news-header-inner h1 {
    color: var(--color-white);
    font-size: 32px;
  }

  .news-intro {
    color: var(--color-gray);
    margin-top: var(--space-1);
  }

  .news-content {
    padding: var(--space-6) var(--space-3) var(--space-8);
  }

  .news-content-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .news-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  .news-empty {
    color: var(--color-gray);
  }

  @media (min-width: 700px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1000px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>