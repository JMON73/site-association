---
import PageLayout from '../../layouts/PageLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import { SITE } from '../../data/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const evenements = await getCollection('evenements');
  return evenements.map((e) => ({
    params: { slug: e.id },
    props: { evenement: e },
  }));
}

const { evenement } = Astro.props;
const { Content } = await render(evenement);

const dateFormatee = new Intl.DateTimeFormat('fr-FR', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(evenement.data.date);
---

<PageLayout title={evenement.data.title} description={evenement.data.resume}>
  <article class="event-detail">
    <div class="event-detail-header">
      {evenement.data.image ? (
        <img src={evenement.data.image} alt="" class="event-detail-image" />
      ) : (
        <div class="event-detail-placeholder" aria-hidden="true">{evenement.data.type}</div>
      )}
    </div>

    <div class="event-detail-inner">
      <Badge variant="accent">{evenement.data.type}</Badge>
      <h1 class="event-detail-title">{evenement.data.title}</h1>

      <div class="event-detail-meta">
        <p class="event-detail-date">{dateFormatee}</p>
        {evenement.data.lieu && <p class="event-detail-lieu">{evenement.data.lieu}</p>}
        {evenement.data.familles && <p class="event-detail-familles">Ouvert aux familles</p>}
      </div>

      <div class="event-detail-body">
        <Content />
      </div>

 {!evenement.data.termine && evenement.data.date >= new Date() && (
  <div class="event-participation">
    <h2 class="event-participation-title">Je participe</h2>
    <p class="event-participation-subtitle">Confirmez votre présence en quelques secondes.</p>

    <form
  action="https://api.web3forms.com/submit"
  method="POST"
  class="event-detail-form"
  id="event-participation-form"
>
  <input type="hidden" name="access_key" value={SITE.web3formsKey} />
  <input type="hidden" name="subject" value={`Inscription : ${evenement.data.title}`} />
  <input type="hidden" name="evenement" value={evenement.data.title} />
  <input type="checkbox" name="botcheck" style="display: none;" />

      <div class="event-form-field">
        <label for="nom">Nom et prénom</label>
        <input type="text" id="nom" name="nom" required />
      </div>

      <div class="event-form-field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div class="event-form-row">
        <div class="event-form-field">
          <label for="adultes_adherents">Adultes adhérents</label>
          <input type="number" id="adultes_adherents" name="adultes_adherents" min="0" value="0" required />
        </div>

        <div class="event-form-field">
          <label for="adultes_invites">Adultes invités</label>
          <input type="number" id="adultes_invites" name="adultes_invites" min="0" value="0" required />
        </div>

        <div class="event-form-field">
          <label for="moins_16_ans">- de 16 ans</label>
          <input type="number" id="moins_16_ans" name="moins_16_ans" min="0" value="0" required />
        </div>
      </div>

      <button type="submit" class="event-form-submit">Confirmer ma participation</button>
    </form>

    <p class="event-participation-success" id="event-participation-success" hidden>
      ✓ Participation envoyée ! Nous avons bien reçu votre demande.
    </p>
  </div>
)}
      <a href="/agenda" class="event-detail-back">&larr; Retour à l'agenda</a>
    </div>
  </article>
</PageLayout>

<style>
  .event-detail-header {
    width: 100%;
    height: 320px;
    background-color: var(--color-gray-light);
  }

  .event-detail-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-detail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .event-detail-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-3);
  }

  .event-detail-title {
    font-size: 32px;
    margin-top: var(--space-2);
  }

  .event-detail-meta {
    margin-top: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-gray-light);
  }

  .event-detail-date {
    font-size: 16px;
    font-weight: 500;
    text-transform: capitalize;
  }

  .event-detail-lieu {
    font-size: 15px;
    color: var(--color-gray);
    margin-top: 4px;
  }

  .event-detail-familles {
    font-size: 14px;
    color: var(--color-red);
    font-weight: 500;
    margin-top: 6px;
  }

  .event-detail-body {
    margin-top: var(--space-4);
    font-size: 16px;
    line-height: 1.7;
  }

  .event-detail-cta {
    margin-top: var(--space-4);
  }

  .event-detail-back {
    display: inline-block;
    margin-top: var(--space-5);
    font-size: 14px;
    color: var(--color-gray);
  }

  @media (min-width: 700px) {
    .event-detail-title {
      font-size: 40px;
    }
  }
.event-participation {
  margin-top: var(--space-6);
  padding: var(--space-4);
  background-color: var(--color-gray-light);
  border-radius: var(--radius-lg);
}

.event-participation-title {
  font-size: 22px;
}

.event-participation-subtitle {
  font-size: 14px;
  color: var(--color-gray);
  margin-top: 4px;
  margin-bottom: var(--space-3);
}

.event-detail-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.event-form-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-3);
}

.event-form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.event-form-field label {
  font-size: 14px;
  font-weight: 500;
}

.event-form-field input {
  font-family: var(--font-sans);
  font-size: 15px;
  padding: 12px 14px;
  border: 1px solid var(--color-gray-light);
  border-radius: var(--radius-sm);
  background-color: var(--color-white);
}

.event-form-field input:focus-visible {
  outline: 2px solid var(--color-red);
  outline-offset: 2px;
}

.event-form-submit {
  align-self: flex-start;
  margin-top: var(--space-1);
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 500;
  padding: 12px 24px;
  background-color: var(--color-red);
  color: var(--color-white);
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background-color var(--transition-base);
}

.event-form-submit:hover {
  background-color: var(--color-red-dark);
}

.event-form-submit:disabled {
  opacity: 0.6;
  cursor: default;
}

.event-participation-success {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-red);
  padding: var(--space-2) 0;
}

@media (min-width: 600px) {
  .event-form-row {
    grid-template-columns: repeat(3, 1fr);
  }
}
<script>
  const form = document.getElementById('event-participation-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('event-participation-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('.event-form-submit') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi en cours...';

    const formData = new FormData(form);
    const params = new URLSearchParams(formData as any).toString();

    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params,
      });

      form.hidden = true;
      if (successMsg) successMsg.hidden = false;
    } catch (error) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Confirmer ma participation';
      alert("Une erreur est survenue, merci de réessayer.");
    }
  });
</script>
</style>