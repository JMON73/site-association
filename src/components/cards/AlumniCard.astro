---
interface Props {
  nom: string;
  photo?: string;
  periode: string;
  poste?: string;
}

const { nom, photo, periode, poste } = Astro.props;
---

<div class="alumni-card">
  <div class="alumni-card-photo-wrap">
    {photo ? (
      <img src={photo} alt={nom} class="alumni-card-photo" />
    ) : (
      <div class="alumni-card-placeholder" aria-hidden="true">
        {nom.charAt(0)}
      </div>
    )}
  </div>
  <p class="alumni-card-nom">{nom}</p>
  <p class="alumni-card-periode">{periode}</p>
  {poste && <p class="alumni-card-poste">{poste}</p>}
</div>

<style>
  .alumni-card {
    text-align: center;
  }

  .alumni-card-photo-wrap {
    aspect-ratio: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-2);
    background-color: var(--color-gray-light);
  }

  .alumni-card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .alumni-card:hover .alumni-card-photo {
    transform: scale(1.04);
  }

  .alumni-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    font-weight: 600;
    color: var(--color-gray);
  }

  .alumni-card-nom {
    font-size: 16px;
    font-weight: 500;
  }

  .alumni-card-periode {
    font-size: 14px;
    color: var(--color-gray);
    margin-top: 2px;
  }

  .alumni-card-poste {
    font-size: 13px;
    color: var(--color-red);
    margin-top: 2px;
  }
</style>