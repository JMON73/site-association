---
import Badge from '../ui/Badge.astro';

interface Props {
  slug: string;
  title: string;
  type: string;
  date: Date;
  lieu?: string;
  familles: boolean;
  image?: string;
}

const { slug, title, type, date, lieu, familles, image } = Astro.props;

const dateFormatee = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(date);
---

<a href={`/agenda/${slug}`} class="event-card">
  <div class="event-card-image-wrap">
    {image ? (
      <img src={image} alt="" class="event-card-image" loading="lazy" />
    ) : (
      <div class="event-card-placeholder" aria-hidden="true">{type}</div>
    )}
    <span class="event-card-date-badge">{dateFormatee}</span>
  </div>

  <div class="event-card-content">
    <Badge>{type}</Badge>
    <h3 class="event-card-title">{title}</h3>
    {lieu && <p class="event-card-lieu">{lieu}</p>}
    {familles && <p class="event-card-familles">Ouvert aux familles</p>}
  </div>
</a>

<style>
  .event-card {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-light);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .event-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .event-card-image-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    background-color: var(--color-gray-light);
  }

  .event-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .event-card-date-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: var(--color-red);
    color: var(--color-white);
    font-size: 13px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }

  .event-card-content {
    padding: var(--space-3);
  }

  .event-card-title {
    font-size: 18px;
    margin-top: var(--space-1);
  }

  .event-card-lieu {
    font-size: 14px;
    color: var(--color-gray);
    margin-top: 4px;
  }

  .event-card-familles {
    font-size: 13px;
    color: var(--color-red);
    margin-top: 6px;
    font-weight: 500;
  }
</style>