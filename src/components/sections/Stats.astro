---
interface Stat {
  chiffre: string;
  label: string;
}

const stats: Stat[] = [
  { chiffre: "150", label: "Membres" },
  { chiffre: "10+", label: "Événements par an" },
  { chiffre: "40", label: "Années d'existence" },
  { chiffre: "3", label: "Clubs réunis" },
];
---

<section class="stats">
  <div class="stats-inner">
    {stats.map((stat) => (
      <div class="stat-item">
        <p class="stat-chiffre">{stat.chiffre}</p>
        <p class="stat-label">{stat.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    padding: var(--space-8) var(--space-3);
    background-color: var(--color-black);
  }

  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    text-align: center;
  }

  .stat-chiffre {
    font-size: 40px;
    font-weight: 600;
    color: var(--color-white);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 14px;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  @media (min-width: 700px) {
    .stats-inner {
      grid-template-columns: repeat(4, 1fr);
    }

    .stat-chiffre {
      font-size: 56px;
    }
  }
</style>