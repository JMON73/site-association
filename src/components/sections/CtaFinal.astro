---
import Button from '../ui/Button.astro';
---

<section class="cta-final">
  <div class="cta-final-inner">
    <h2 class="cta-final-title">Rejoignez le CARAU</h2>
    <p class="cta-final-text">
      Que vous ayez porté le maillot ou simplement envie de partager nos valeurs,
      il y a toujours une place au CARAU.
    </p>

    <div class="cta-final-actions">
      <Button href="/adherer" size="large">Adhérer</Button>
      <Button href="/contact" variant="secondary" size="large">Nous contacter</Button>
    </div>
  </div>
</section>

<style>
  .cta-final {
    padding: var(--space-12) var(--space-3);
    background-color: var(--color-white);
    text-align: center;
  }

  .cta-final-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .cta-final-title {
    font-size: 28px;
    margin-bottom: var(--space-2);
  }

  .cta-final-text {
    font-size: 16px;
    color: var(--color-gray);
    margin-bottom: var(--space-4);
  }

  .cta-final-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
  }

  @media (min-width: 700px) {
    .cta-final-title {
      font-size: 36px;
    }

    .cta-final-actions {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>