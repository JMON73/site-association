---
import Button from '../ui/Button.astro';

interface Props {
  title: string;
  subtitle?: string;
  image: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  image,
  ctaLabel = "Découvrir le CARAU",
  ctaHref = "/association",
} = Astro.props;
---

<section class="hero">
  <img src={image} alt="" class="hero-image" />
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <h1 class="hero-title">{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    <Button href={ctaHref} size="large" class="hero-cta">{ctaLabel}</Button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 480px;
    max-height: 720px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(20, 20, 20, 0.75) 0%,
      rgba(20, 20, 20, 0.25) 50%,
      rgba(20, 20, 20, 0.05) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-3) var(--space-6);
    color: var(--color-white);
  }

  .hero-title {
    color: var(--color-white);
    font-size: 32px;
    max-width: 600px;
    margin-bottom: var(--space-2);
  }

  .hero-subtitle {
    font-size: 16px;
    color: var(--color-white);
    opacity: 0.9;
    max-width: 480px;
    margin-bottom: var(--space-3);
  }

  @media (min-width: 900px) {
    .hero-title {
      font-size: 56px;
    }

    .hero-subtitle {
      font-size: 18px;
    }
  }
</style>