---
import { render } from 'astro:content';

interface Props {
  etapes: any[];
}

const { etapes } = Astro.props;
---

<div class="timeline">
  {etapes.map(async (etape) => {
    const { Content } = await render(etape);
    return (
      <div class="timeline-item">
        <div class="timeline-marker">
          <span class="timeline-annee">{etape.data.annee}</span>
        </div>
        <div class="timeline-content">
          {etape.data.photo && (
            <img src={etape.data.photo} alt="" class="timeline-photo" loading="lazy" />
          )}
          <h3 class="timeline-titre">{etape.data.titre}</h3>
          <div class="timeline-text">
            <Content />
          </div>
        </div>
      </div>
    );
  })}
</div>

<style>
  .timeline {
    position: relative;
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-gray-light);
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--space-6);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--space-4) - 6px);
    top: 0;
    width: 12px;
    height: 12px;
    background-color: var(--color-red);
    border-radius: 50%;
  }

  .timeline-annee {
    position: absolute;
    top: -4px;
    left: var(--space-2);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-red);
  }

  .timeline-content {
    padding-top: var(--space-4);
  }

  .timeline-photo {
    width: 100%;
    max-width: 400px;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-2);
  }

  .timeline-titre {
    font-size: 20px;
    margin-bottom: var(--space-1);
  }

  .timeline-text {
    font-size: 15px;
    color: var(--color-black);
  }
</style>